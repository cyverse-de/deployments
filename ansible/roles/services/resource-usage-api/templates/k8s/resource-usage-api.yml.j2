apiVersion: apps/v1
kind: Deployment
metadata:
  name: resource-usage-api
spec:
  replicas: {{ resource_usage_api_replicas }}
  selector:
    matchLabels:
      de-app: resource-usage-api
  template:
    metadata:
      labels:
        de-app: resource-usage-api
        app: de
    spec:
      serviceAccount: configurator
{% if resource_usage_api_pod_anti_affinity %}
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchExpressions:
                  - key: de-app
                    operator: In
                    values:
                      - resource-usage-api
              topologyKey: kubernetes.io/hostname
{% endif %}
      restartPolicy: Always
      volumes:
        - name: resource-usage-api-configs
          secret:
            secretName: resource-usage-api-configs
            items:
              - key: jobservices.yml
                path: service.yml
      containers:
        - name: resource-usage-api
          image: harbor.cyverse.org/de/resource-usage-api
          resources:
            requests:
              cpu: "1m"
              memory: "128Mi"
              ephemeral-storage: "1Gi"
            limits:
              cpu: "100m"
              memory: "256Mi"
              ephemeral-storage: "1Gi"
          env:
            - name: TZ
              valueFrom:
                configMapKeyRef:
                  name: timezone
                  key: timezone
            - name: OTEL_TRACES_EXPORTER
              valueFrom:
                secretKeyRef:
                  name: configs
                  key: OTEL_TRACES_EXPORTER
            - name: OTEL_EXPORTER_JAEGER_ENDPOINT
              valueFrom:
                secretKeyRef:
                  name: configs
                  key: OTEL_EXPORTER_JAEGER_HTTP_ENDPOINT
          args:
            - --log-level
            - debug
            - --subscriptions-base-uri
            - {{ baseurls_subscriptions }}
          ports:
            - name: listen-port
              containerPort: 60000
          volumeMounts:
            - name: resource-usage-api-configs
              mountPath: /etc/cyverse/de/configs
              readOnly: true
          livenessProbe:
            httpGet:
              path: /
              port: 60000
            initialDelaySeconds: 5
            periodSeconds: 5
          readinessProbe:
            httpGet:
              path: /
              port: 60000
            initialDelaySeconds: 5
            periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: resource-usage-api
spec:
  selector:
    de-app: resource-usage-api
  ports:
    - protocol: TCP
      port: 80
      targetPort: listen-port
